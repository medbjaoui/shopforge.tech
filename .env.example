# Database
DB_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://shopforge:change_me_strong_password@db:5432/shopforge

# JWT
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
API_PORT=3001

# Super Admin (seed initial)
SUPER_ADMIN_EMAIL=admin@shopforge.tech
SUPER_ADMIN_PASSWORD=change_me_super_admin_password

# Cloudflare Tunnel (production uniquement)
# Obtenir depuis: https://one.dash.cloudflare.com/ → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
