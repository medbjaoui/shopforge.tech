# ============================================================
# ShopForge — Variables d'environnement PRODUCTION
# Copier ce fichier en .env sur le VPS, puis compléter.
# ============================================================

# ── Base de données ──────────────────────────────────────────
DB_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_FORT_32_CHARS

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=REMPLACER_PAR_SECRET_ALEATOIRE_MIN_64_CHARS
JWT_REFRESH_SECRET=REMPLACER_PAR_AUTRE_SECRET_ALEATOIRE_MIN_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001

# ── Super Admin (premier lancement uniquement) ────────────────
SUPER_ADMIN_EMAIL=admin@shopforge.tech
SUPER_ADMIN_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_FORT

# ── Cloudflare Tunnel ─────────────────────────────────────────
# 1. Aller sur https://one.dash.cloudflare.com/
# 2. Networks → Tunnels → Create a tunnel
# 3. Nommer le tunnel "shopforge-prod"
# 4. Copier le token ci-dessous
# 5. Configurer les routes publiques dans le dashboard Cloudflare :
#    - api.shopforge.tech  → http://api:3001
#    - shopforge.tech      → http://web:3000
#    - *.shopforge.tech    → http://web:3000
CLOUDFLARE_TUNNEL_TOKEN=REMPLACER_PAR_TOKEN_CLOUDFLARE_TUNNEL
